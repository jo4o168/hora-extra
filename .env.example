# --- Auth.js (login Google) ---
# URL pública do app (dev). Em produção use https://seu-dominio.com
AUTH_URL=http://localhost:3000
# Gere com: openssl rand -base64 32
# Se existir .env.local com AUTH_SECRET= vazio, ele SOBRESCREVE o .env — remova a linha vazia.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Domínios corporativos permitidos (separados por vírgula). Ex.: empresa.com,empresa.org
ACCESS_ALLOWED_EMAIL_DOMAINS=
# E-mails com acesso global (RH/admin), separados por vírgula.
ACCESS_ADMIN_EMAILS=
# Mapa opcional para acesso restrito por gestor quando não houver e-mail na aba de gestores.
# Formato: email@empresa.com=GESTOR1|GESTOR2;outro@empresa.com=GESTOR3
ACCESS_USER_GESTOR_IDS=

# --- Conta de serviço (Google Sheets) ---
# 1) Google Cloud → IAM → Contas de serviço → criar chave JSON
# 2) Compartilhe AS DUAS planilhas com o e-mail da conta (ex.: sheets-bot@proj.iam.gserviceaccount.com) como Editor
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Cole a chave privada com \n nas quebras de linha, ou uma linha só entre aspas
GOOGLE_PRIVATE_KEY=

# --- Planilha 1: CADASTRO (gestores, colaboradores, eventos em abas ou intervalos separados) ---
# ID da planilha (entre /d/ e /edit na URL)
GOOGLE_SHEETS_CADASTRO_SPREADSHEET_ID=
# Primeira linha de cada intervalo = cabeçalhos. Colunas esperadas (nomes flexíveis):
# Gestores: id, nome, email (recomendado para vincular acesso por gestor)
# Colaboradores: id, nome, cargo, regime (CLT|PJ), salario ou salário, valor_hora (PJ), gestor_id
# Eventos: id, nome
GOOGLE_SHEETS_CADASTRO_GESTORES_RANGE=Gestores!A1:B200
GOOGLE_SHEETS_CADASTRO_COLABORADORES_RANGE=Colaboradores!A1:H500
GOOGLE_SHEETS_CADASTRO_EVENTOS_RANGE=Eventos!A1:B200

# --- Planilha 2: LANÇAMENTOS (pode ser o mesmo ID da planilha 1) ---
GOOGLE_SHEETS_LANCAMENTOS_SPREADSHEET_ID=
# Leitura para o relatório (neste projeto, cabeçalho na linha 3 da aba)
# Layout da aba "Horas Extras":
# Colaborador_id | Gestor_id | PJ/CLT | Entrada | Saída | Horas Extras totais | Data | Evento_id |
# Extra 50% | Extra100% | Salário | Valor/Hora | Valor - 100% | Valor - 50% |
# Horas extras 60% | Banco de horas 40% | Já foi Pago? | Feriado Nacional?
GOOGLE_SHEETS_LANCAMENTOS_READ_RANGE='Horas Extras'!A3:R5000
# Append segue essa mesma ordem de colunas.
GOOGLE_SHEETS_LANCAMENTOS_APPEND_RANGE='Horas Extras'!A3:R

# Legado (uma planilha só): se LANCAMENTOS_SPREADSHEET_ID não existir, usa:
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_LANCAMENTOS_RANGE=

# Observação: sem essas variáveis preenchidas corretamente, a aplicação não usa dados fictícios
# e retornará erro informando configuração ausente/inválida do Google Sheets.
